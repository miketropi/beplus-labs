# ─── Database (MySQL) ────────────────────────────────────
# Connection string for Prisma ORM.
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:password@localhost:3306/beplus_labs"

# ─── Admin ────────────────────────────────────────────────
# Secret key used to authenticate into the /admin dashboard.
# Generate one with: openssl rand -hex 32
ADMIN_SECRET=change-me-to-a-random-secret

# ─── SMTP Mail ───────────────────────────────────────────
# Used by nodemailer to send contact form submissions,
# beta program notifications, and other transactional emails.
# Supported: any SMTP provider (Gmail, SendGrid, Mailgun, Postmark, etc.)

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
MAIL_FROM=noreply@bepluslabs.com
MAIL_TO=hello@bepluslabs.com

# ─── Klaviyo ────────────────────────────────────────────────
# Public list ID for the newsletter subscribe form in the footer.
# Find it in Klaviyo: Lists & Segments > [Your List] > List Name > List ID
NEXT_PUBLIC_KLAVIYO_LIST_ID=your-klaviyo-list-id

# ─── Discord ──────────────────────────────────────────────
# Public invite link for the "Join Discord" button in the header.
NEXT_PUBLIC_DISCORD_INVITE_URL=https://discord.gg/your-invite-code
