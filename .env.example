# ─── Database (MySQL) ────────────────────────────────────
# Connection string for Prisma ORM.
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:password@localhost:3306/beplus_labs"

# ─── Admin ────────────────────────────────────────────────
# Secret key used to authenticate into the /admin dashboard.
# Generate one with: openssl rand -hex 32
ADMIN_SECRET=change-me-to-a-random-secret

# ─── SMTP Mail ───────────────────────────────────────────
# Used by nodemailer to send contact form submissions,
# beta program notifications, and other transactional emails.
# Supported: any SMTP provider (Gmail, SendGrid, Mailgun, Postmark, etc.)

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
MAIL_FROM=noreply@bepluslabs.com
MAIL_TO=hello@bepluslabs.com
